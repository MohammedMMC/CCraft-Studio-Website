generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  firstName String?
  lastName  String?
  imageUrl  String?
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  apiToken  String?  @unique

  tempProjectFiles TempProjectFiles?

  reviewedLogs       ReviewData[]     @relation("ProjectReviewer")
  projects           Project[]        @relation("ProjectOwner")
  projectComments    ProjectComment[]
  tempProjectFilesId String?

  @@index([email])
}

model Project {
  id               String       @id @default(cuid())
  ownerId          String
  name             String
  shortDescription String
  description      String
  version          String
  tags             String[]
  projectFileUrl   String
  projectFileName  String
  projectFileSize  Int
  downloads        Int          @default(0)
  likes            String[]     @default([])
  reviewed         Boolean      @default(false)
  reviewLog        ReviewData[]
  publishDate      DateTime
  projectUpdatedAt DateTime
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  owner    User             @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  images   ProjectImage[]
  comments ProjectComment[]
  files    ProjectFiles?

  @@index([ownerId, createdAt(sort: Desc)])
  @@index([reviewed, createdAt(sort: Desc)])
  @@index([publishDate(sort: Desc)])
}

model ReviewData {
  id           String   @id @default(cuid())
  projectId    String
  reviewedById String
  message      String
  rejected     Boolean  @default(false)
  reviewedAt   DateTime @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewedBy User    @relation("ProjectReviewer", fields: [reviewedById], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([reviewedById])
}

model ProjectImage {
  id          String   @id @default(cuid())
  projectId   String
  url         String
  pathname    String
  contentType String
  size        Int
  isMain      Boolean  @default(false)
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, isMain])
}

model ProjectComment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  text      String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model ProjectFiles {
  id                String   @id @default(cuid())
  projectId         String   @unique
  url               String
  pathname          String
  size              Int
  componentsVersion String
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model TempProjectFiles {
  id                String   @id @default(cuid())
  userId            String   @unique
  url               String
  pathname          String
  size              Int
  componentsVersion String
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model componentsVersions {
  id        String   @id @default(cuid())
  version   String   @unique
  url       String
  pathname  String
  size      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
